{
  "name": "portal-vesper",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:desktop": "npm run dev --workspace=apps/desktop",
    "build:web": "npm run build --workspace=apps/web",
    "build:desktop": "npm run build --workspace=apps/desktop",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "infra:up": "docker compose --env-file .env -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose --env-file .env -f infra/docker-compose.yml down",
    "infra:logs": "docker compose --env-file .env -f infra/docker-compose.yml logs -f",
    "infra:app": "docker compose --env-file .env -f infra/docker-compose.yml --profile app up -d",
    "backend:dev": "cd backend && .venv\\Scripts\\python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000 --no-access-log",
    "backend:migrate": "cd backend && .venv\\Scripts\\python -m alembic upgrade head",
    "backend:seed": "cd backend && .venv\\Scripts\\python -m seeds.initial_seed",
    "backend:test": "cd backend && .venv\\Scripts\\python -m pytest tests/ -v"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
