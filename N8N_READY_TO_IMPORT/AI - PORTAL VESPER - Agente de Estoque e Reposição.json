      "id": "d41a9cbe-957c-4f0d-ac88-9ac9477804aa",
      "name": "Consultar Ordens de Produção",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1136,
        496
      ]
    },
    {
      "parameters": {
        "jsCode": "const estoque = $input.first().json;\nconst ops = $('Consultar Ordens de Produção').all().map(i => i.json);\n\nconst opsDoMaterial = ops.filter(op => op.material === estoque.id);\nconst demandaTotal = opsDoMaterial.reduce((sum, op) => sum + op.quantidade, 0);\nconst deficit = estoque.quantidade - demandaTotal;\nconst quantidadeReposicao = Math.max(estoque.maximo - estoque.quantidade, Math.abs(deficit));\n\nreturn [{\n  json: {\n    material: estoque.id,\n    nome: estoque.nome,\n    quantidadeAtual: estoque.quantidade,\n    minimo: estoque.minimo,\n    maximo: estoque.maximo,\n    demandaOPs: demandaTotal,\n    deficit: deficit,\n    quantidadeReposicao: quantidadeReposicao,\n    opsVinculadas: opsDoMaterial.length,\n    opsDetalhes: opsDoMaterial,\n    localizacao: estoque.localizacao,\n    unidade: estoque.unidade\n  }\n}];"
      },
