    {
      "parameters": {
        "resume": "form",
        "formTitle": "Aprovação de Proposta Comercial - VESPER",
        "formDescription": "=&lt;h3&gt;Proposta requer aprovação&lt;/h3&gt;\n&lt;p&gt;&lt;strong&gt;Cliente:&lt;/strong&gt; {{ $json.output.cliente }}&lt;/p&gt;\n&lt;p&gt;&lt;strong&gt;Produto:&lt;/strong&gt; {{ $json.output.produto }}&lt;/p&gt;\n&lt;p&gt;&lt;strong&gt;Valor Total:&lt;/strong&gt; R$ {{ $json.output.preco_total }}&lt;/p&gt;\n&lt;p&gt;&lt;strong&gt;Desconto:&lt;/strong&gt; {{ $json.output.desconto_aplicado }}%&lt;/p&gt;\n&lt;p&gt;&lt;strong&gt;Risco:&lt;/strong&gt; {{ $json.output.risco_comercial }}&lt;/p&gt;\n&lt;p&gt;&lt;strong&gt;Justificativa:&lt;/strong&gt; {{ $json.output.justificativa }}&lt;/p&gt;",
        "formFields": {
          "values": [
            {
              "fieldLabel": "Decisão",
              "fieldType": "dropdown",
              "fieldOptions": {
                "values": [
                  {
                    "option": "Aprovar"
                  },
                  {
                    "option": "Rejeitar"
                  },
                  {
                    "option": "Solicitar Revisão"
                  }
                ]
              },
              "requiredField": true
            },
            {
              "fieldLabel": "Observações do Aprovador",
              "fieldType": "textarea",
              "placeholder": "Comentários adicionais sobre a decisão"
            }
          ]
        },
        "options": {}
      },
