    {
      "parameters": {
        "public": true,
        "initialMessages": "Olá! Sou o Agente Empresarial do Portal Vesper.\n\nPosso ajudar com:\n• Compras e Cotações\n• Propostas Comerciais\n• Produção e Kanban\n• Ordens de Produção (OPs)\n• HelpDesk e TI\n• RH e Financeiro\n• Estoque e Qualidade\n• Arquivos/NAS\n• Aprovações e Relatórios\n\nComo posso ajudar?",
        "options": {
          "loadPreviousSession": "memory",
          "showWelcomeScreen": true,
          "getStarted": "Iniciar Conversa",
          "subtitle": "Seu assistente inteligente para gestão empresarial",
          "title": "Portal Vesper - Agente Empresarial",
          "responseMode": "streaming"
        }
