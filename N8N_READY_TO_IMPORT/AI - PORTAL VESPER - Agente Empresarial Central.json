        "jsCode": "// Recebe query do agente\nconst query = $input.item.json.query;\n\n// Simula busca (em produção, chamaria API do Portal)\nconst resultado = {\n  status: 'sucesso',\n  dados: {\n    query: query,\n    timestamp: new Date().toISOString(),\n    fonte: 'Portal Vesper'\n  },\n  mensagem: 'Dados recuperados com sucesso. Em produção, conectar à API real do Portal Vesper.'\n};\n\nreturn JSON.stringify(resultado);"
