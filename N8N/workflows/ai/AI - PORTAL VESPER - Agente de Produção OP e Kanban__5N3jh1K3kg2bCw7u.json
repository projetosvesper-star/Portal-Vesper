      {
        "parameters": {
          "jsCode": "// Registrar log de auditoria\nconst items = $input.all();\nconst logs = items.map(item => ({\n  timestamp: new Date().toISOString(),\n  workflow_id: $workflow.id,\n  execution_id: $execution.id,\n  item_id: item.json.item_id || 'N/A',\n  acao: item.json.approved ? 'aprovado' : 'rejeitado',\n  usuario: item.json.approvedBy || 'sistema',\n  detalhes: {\n    resumo: item.json.resumo,\n    score: item.json.score,\n    problemas: item.json.problemas,\n    recomendacoes: item.json.recomendacoes\n  }\n}));\n\n// Retornar logs para próximo nó (pode ser enviado para banco de dados)\nreturn logs.map(log => ({ json: log }));"
        },
        "id": "0fd378c7-3ce9-42e4-b367-47035a803261",
        "name": "Registrar Auditoria",
